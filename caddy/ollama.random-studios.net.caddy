@homepage {
  path /
}

@costi {
  header Authorization "Bearer {$COSTI_TOKEN}"
}

handle @costi {
  reverse_proxy 127.0.0.1:8000 {
    header_up Host {upstream_hostport}
  }
}

@dorin {
  header Authorization "Bearer {$DORIN_TOKEN}"
}

handle @dorin {
  reverse_proxy 127.0.0.1:8000 {
    header_up Host {upstream_hostport}
  }
}

@sebi {
  header Authorization "Bearer {$SEBI_TOKEN}"
}

handle @sebi {
  reverse_proxy 127.0.0.1:8000 {
    header_up Host {upstream_hostport}
  }
}

handle @homepage {
  root * __OLLAMA_SITE_ROOT__
  rewrite * /index.html
  file_server
}

handle {
  respond "unauthorized" 401
}
